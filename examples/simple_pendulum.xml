<mujoco model="inverted_single_pendulum">
  <compiler coordinate="local" inertiafromgeom="true" />
  <option gravity="0 0 -9.81" timestep="0.002" /> 

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" castshadow="true"/>
    <geom name="ground" type="plane" size="5 5 0.1" rgba="0.15 0.15 0.15 1" />

    <body name="link_1" pos="0 0 1.0">
      <joint name="joint_1" type="hinge" axis="0 1 0" damping="0.0"/>
      
      <geom name="arm_geom" type="capsule" fromto="0 0 0 0 0 -0.6" size="0.03" mass="2.0" rgba="0.2 0.6 0.8 1" />

      <geom name="bob_geom" type="sphere" size="0.1" pos="0 0 -0.6" mass="3.5" rgba="0.8 0.3 0.2 1" />
      
      <site name="tip" pos="0 0 -0.6" size="0.01" />
    </body>
  </worldbody>

    <actuator>
      <motor joint="joint_1" ctrlrange="-5 5" ctrllimited="true"/>
    </actuator>
</mujoco>